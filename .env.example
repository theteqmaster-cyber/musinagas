APP_ENV=development
APP_NAME="Musina Gas"
APP_URL=http://localhost:8080
APP_SECRET=musinagas-secret-key-32-chars-minimum!!

# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Supabase Direct PostgreSQL Connection String (Transaction / Session pooling mode)
# Example: postgresql://postgres.xxxx:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Or: postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Storage & Third Party
R2_BUCKET_URL=
R2_ACCESS_KEY=
R2_SECRET_KEY=
